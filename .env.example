# Copy to .env and fill in. This file is Make syntax — no quotes, no `export`.
# Values may contain spaces; everything after `=` up to newline is the value.

# --- Project identity (optional overrides; defaults come from the Makefile) ---

# Executable name and bundle display name.
# APP_NAME     = ScreenPresenter
# DISPLAY_NAME = Screen Presenter

# Reverse-DNS bundle identifier. Must match the one on your Developer ID cert
# if you plan to notarize.
# BUNDLE_ID    = com.epatel.ScreenPresenter

# --- Signing & notarization ---

# From `security find-identity -v -p codesigning` — include the full line
# starting with "Developer ID Application".
SIGNING_IDENTITY = Developer ID Application: Your Name (TEAMID)

# Apple ID email used on developer.apple.com
APPLE_ID = you@example.com

# 10-character team ID from developer.apple.com/account
TEAM_ID = XXXXXXXXXX

# App-specific password generated at appleid.apple.com -> Sign-In and Security.
# Not your Apple ID password.
APP_PASSWORD = xxxx-xxxx-xxxx-xxxx
